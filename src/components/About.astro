---
import { t } from '../lib/translations';
const base = import.meta.env.BASE_URL;
---
<section id="about" class="py-24 bg-stone">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">

      <!-- Image block -->
      <div class="relative reveal">
        <div class="aspect-[4/5] overflow-hidden rounded-sm">
          <img
            src={`${base}images/about-vineyard.jpg`}
            alt="Vinograd Vinarija Vrh"
            class="w-full h-full object-cover"
            style="background: linear-gradient(135deg, #4a5e2d 0%, #8b6a3e 100%);"
            loading="lazy"
          />
        </div>
        <!-- Overlapping smaller image -->
        <div class="absolute -bottom-8 -right-6 md:-right-10 w-2/5 aspect-[4/3] overflow-hidden rounded-sm shadow-xl border border-parch">
          <img
            src={`${base}images/about-cellar.jpg`}
            alt="Klet Vinarija Vrh"
            class="w-full h-full object-cover"
            style="background: linear-gradient(135deg, #1a1208 0%, #5c1a1a 100%);"
            loading="lazy"
          />
        </div>
        <!-- Badge -->
        <div class="absolute -top-4 -left-4 bg-wine text-white w-20 h-20 rounded-full flex flex-col items-center justify-center shadow-lg">
          <span class="font-label text-[9px] tracking-widest uppercase">est.</span>
          <span class="font-display text-xl leading-none">1962</span>
        </div>
      </div>

      <!-- Text block -->
      <div class="md:pl-4 lg:pl-8 reveal" style="transition-delay: 0.15s">
        <p class="font-label text-xs tracking-[0.25em] uppercase text-oak mb-4" id="ab-badge">
          {t.sl.about_badge}
        </p>
        <h2 class="font-display text-4xl md:text-5xl text-ink leading-tight mb-8 whitespace-pre-line" id="ab-heading">
          {t.sl.about_heading}
        </h2>
        <div class="space-y-5 text-muted font-sans font-light leading-relaxed text-[15px]">
          <p id="ab-p1">{t.sl.about_p1}</p>
          <p id="ab-p2">{t.sl.about_p2}</p>
          <p id="ab-p3">{t.sl.about_p3}</p>
        </div>
        <!-- Signature line -->
        <div class="mt-10 pt-8 border-t border-wine/15 flex items-center gap-4">
          <div class="w-12 h-12 rounded-full bg-parch border border-wine/20 flex items-center justify-center">
            <span class="font-display text-xl text-wine">LV</span>
          </div>
          <div>
            <div class="font-display text-base text-ink">Luka Vrhovec</div>
            <div class="font-label text-xs tracking-wider text-muted uppercase">Vinar · 3. generacija</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  import type { Lang } from '../lib/translations';
  import { t } from '../lib/translations';

  type K = keyof typeof t.sl;
  const map: Record<string, K> = {
    'ab-badge':   'about_badge',
    'ab-heading': 'about_heading',
    'ab-p1':      'about_p1',
    'ab-p2':      'about_p2',
    'ab-p3':      'about_p3',
  };
  document.addEventListener('langchange', (e) => {
    const lang = (e as CustomEvent<Lang>).detail;
    for (const [id, key] of Object.entries(map)) {
      const el = document.getElementById(id);
      if (el) el.textContent = t[lang][key];
    }
  });
</script>
