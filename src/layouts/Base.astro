---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Vinarija Vrh — Goriška brda',
  description = 'Rodinná vinárna Vrhovec z Goriška brda. Tri generacije, 8 vin, 12 držav izvoza.',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="sl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- OG -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${base}images/og-image.webp`} />
  <meta property="og:type" content="website" />

  <!-- Theme -->
  <meta name="theme-color" content="#5c1a1a" />

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://unpkg.com" />
  <link rel="preconnect" href="https://a.basemaps.cartocdn.com" />

  <!-- Preload hero -->
  <link rel="preload" as="image" href={`${base}images/hero-bg.webp`} />

  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>
